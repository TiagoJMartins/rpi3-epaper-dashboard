[Unit]
Description=E-Paper Widget Dashboard
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=/home/tiago/.local/bin/uv run --with /home/tiago/dashboard dashboard
WorkingDirectory=/home/tiago/dashboard
Environment=HOME=/home/tiago
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
